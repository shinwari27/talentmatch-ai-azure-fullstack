# Copy this file to .env and fill in real values. Never commit .env to Git.

PORT=5000
NODE_ENV=development

# --- Azure SQL (from Phase 5 provisioning) ---
# Server name only, no protocol — e.g. sql-talentmatch-11052.database.windows.net
SQL_SERVER=your-sql-server.database.windows.net
SQL_DATABASE=talentmatchdb
SQL_USER=talentmatchadmin
SQL_PASSWORD=your-sql-password

# --- JWT ---
# Generate a strong random string for this — e.g. `openssl rand -hex 64`
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- CORS ---
# The URL your frontend runs on (Vite dev server by default, or your deployed
# App Service URL once the frontend is deployed)
FRONTEND_URL=http://localhost:5173

# --- Azure Blob Storage (from Phase 5 provisioning) ---
# The storage account name and key from your Phase 5 script output. In
# production (App Service), these come from Key Vault references instead —
# see the Phase 5 infra README. Locally, just use the raw values here.
STORAGE_ACCOUNT_NAME=your-storage-account-name
STORAGE_ACCOUNT_KEY=your-storage-account-key
BLOB_CONTAINER_RESUMES=resumes

# --- Azure AI Document Intelligence (Phase 10) ---
DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key
